#!/bin/bash

set -euo pipefail

source "$SERVICE_PATH/scripts/istio/config"

LABEL="nullplatform.com/service-id=$SERVICE_ID"

echo "=== HTTPRoutes (namespace: $K8S_NAMESPACE) ==="
kubectl get httproutes -n "$K8S_NAMESPACE" -l "$LABEL" -o yaml 2>/dev/null || echo "(none found)"

echo ""
echo "=== AuthorizationPolicies (namespace: $GATEWAY_NAMESPACE) ==="
kubectl get authorizationpolicies -n "$GATEWAY_NAMESPACE" -l "$LABEL" -o yaml 2>/dev/null || echo "(none found)"

echo ""
echo "=== RequestAuthentication (namespace: $GATEWAY_NAMESPACE) ==="
kubectl get requestauthentication -n "$GATEWAY_NAMESPACE" \
  -l "nullplatform.com/managed-by=http-route-access-control" -o yaml 2>/dev/null || echo "(none found)"
